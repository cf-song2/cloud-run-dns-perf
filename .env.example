# ===========================================
# Cloudflare R2 Configuration (REQUIRED)
# ===========================================
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=dns-results

# ===========================================
# Test Configuration (REQUIRED)
# ===========================================
# Timeout for each individual DNS query in seconds
DNS_TIMEOUT_SEC=5

# ===========================================
# DNS Servers (REQUIRED, comma-separated, format: Name=IP)
# ===========================================
DNS_SERVERS=Cloudflare=1.1.1.1,OpenDNS=208.67.222.222

# ===========================================
# Domains to test (REQUIRED, comma-separated)
# ===========================================
DNS_DOMAINS=cloudflare.com,google.com

# ===========================================
# GCP Deployment Configuration (REQUIRED)
# ===========================================
GCP_PROJECT_ID=your_gcp_project_id

# Comma-separated GCP regions to deploy to
# Note: Only use regions that support Cloud Scheduler
# Supported: us-central1, europe-west1, asia-northeast3, asia-south1, 
#            asia-southeast1, australia-southeast1, southamerica-east1, me-central1
# NOT supported: africa-south1 (Cloud Scheduler not available)
GCP_REGIONS=us-central1,europe-west1,asia-northeast3,asia-south1,asia-southeast1,australia-southeast1,southamerica-east1,me-central1

# ===========================================
# Optional Settings (have defaults)
# ===========================================
# Cloud Scheduler cron expression (UTC timezone)
# Examples:
#   */10 * * * *  = Every 10 minutes
#   0 * * * *     = Every hour
#   0 */6 * * *   = Every 6 hours
SCHEDULE_CRON=*/10 * * * *

# Cloud Function resource limits
# FUNCTION_MEMORY=256Mi
# FUNCTION_TIMEOUT=300
# FUNCTION_MAX_INSTANCES=3

# Go runtime version (go121 or go122)
# GO_RUNTIME=go122

# Service account name for Cloud Scheduler
# SCHEDULER_SA_NAME=dns-perf-scheduler-sa
